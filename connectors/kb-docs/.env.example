# kb-docs connector — fill on the VPS only. Real secrets live in 1Password;
# this file is runtime materialization only and must stay uncommitted.

# Bearer token the gateway/worker presents on each call. openssl rand -hex 32.
# Leave empty for local stdio dev (no gateway in front).
CONNECTOR_TOKEN=

# Directory with the knowledge-base documents (.md/.txt). Defaults to ./data.
KB_DOCS_DIR=
