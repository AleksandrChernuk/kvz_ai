# NotebookLM connector runtime config — read-only KB/query connector.
# NOTE: contains NO secrets. Auth is a persistent Chrome profile on the /data
# volume (seeded once, see README), never an env var or committed file.
# Real deployment values materialize from 1Password into the runtime env_file.

# Transport (HTTP behind ContextForge on the internal connectors network).
NOTEBOOKLM_TRANSPORT=http
NOTEBOOKLM_HOST=0.0.0.0
NOTEBOOKLM_PORT=3000

# Headless in the container; the persistent profile makes this reliable.
HEADLESS=true
BROWSER_CHANNEL=chromium

# Read-only surface. `minimal` profile + an explicit disabled-tools list make
# every mutation/auth/session-admin tool physically unavailable to the agent.
NOTEBOOKLM_PROFILE=minimal
NOTEBOOKLM_DISABLED_TOOLS=add_source,add_notebook,update_notebook,remove_notebook,generate_audio,download_audio,cleanup_data,setup_auth,re_auth,select_notebook,close_session,reset_session
