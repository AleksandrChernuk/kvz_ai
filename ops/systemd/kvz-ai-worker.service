[Unit]
Description=KVZ AI Claude Code worker
After=network.target

[Service]
Type=simple
User=__APP_USER__
Group=__APP_USER__
WorkingDirectory=__APP_ROOT__/current
EnvironmentFile=__APP_ROOT__/shared/env/worker.env
ExecStart=/bin/bash __APP_ROOT__/current/agent/scripts/poll.sh
Restart=always
RestartSec=10
StandardOutput=append:__APP_ROOT__/shared/logs/worker/worker.log
StandardError=append:__APP_ROOT__/shared/logs/worker/worker.err.log

[Install]
WantedBy=multi-user.target
