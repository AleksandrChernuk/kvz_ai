# ContextForge MCP Gateway — runtime values materialize from 1Password.

# Gateway auth — the worker presents this token on every call to the gateway.
# Generate: openssl rand -hex 32
CF_AUTH_TOKEN=

# Admin/JWT secret for the gateway management UI/API.
# Generate: openssl rand -hex 32
CF_JWT_SECRET=

# Internal Postgres for the gateway's own registry/state (not the app DB).
CF_DB_USER=contextforge
CF_DB_PASSWORD=
CF_DB_NAME=contextforge
