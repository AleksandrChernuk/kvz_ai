NODE_ENV=production
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
WORKER_ID=kvz-ai-worker-1

# MCP Gateway (ContextForge) — the only way the worker reaches MCP connectors.
# Loopback only; token must match CF_AUTH_TOKEN in ops/contextforge/.env.
MCP_GATEWAY_URL=http://127.0.0.1:4444
MCP_GATEWAY_TOKEN=

# Add only on the VPS or in a secret manager. Do not commit real keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
