NODE_ENV=production
API_URL=https://ai.example.com
WORKER_TOKEN=

# Worker loop
POLL_INTERVAL=5
TOKEN_LIMIT=5000

# MCP Gateway (ContextForge) — the only way the worker reaches MCP connectors.
# Loopback only; token must match CF_AUTH_TOKEN in ops/contextforge/.env.
MCP_GATEWAY_URL=http://127.0.0.1:4444
MCP_GATEWAY_TOKEN=

# LLM runs through the Claude Code / Codex CLIs under your SUBSCRIPTION, not API
# keys. On the worker host run `claude login` (and `codex login` once Codex is
# wired). No ANTHROPIC_API_KEY / OPENAI_API_KEY needed here.
