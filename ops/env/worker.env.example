NODE_ENV=production
API_URL=https://ai.example.com
WORKER_TOKEN=

# Worker loop
POLL_INTERVAL=5
TOKEN_LIMIT=5000

# Orchestration (handle_task.sh decomposition). ORCH_DISABLE=1 is the incident
# kill-switch — tasks still process, just no decomposition. Restart the worker
# after changing. ORCH_STEP_TIMEOUT bounds each CLI call so a hung fan-out can't
# hold the task lock past the 5-min watchdog.
# ORCH_DISABLE=1
ORCH_MAX_CONCURRENCY=3
PLAN_MAX_STEPS=6
ORCH_STEP_TIMEOUT=90

# MCP Gateway (ContextForge) — the only way the worker reaches MCP connectors.
# Loopback only; token must match CF_AUTH_TOKEN in ops/contextforge/.env.
MCP_GATEWAY_URL=http://127.0.0.1:4444
MCP_GATEWAY_TOKEN=

# LLM runs through the Claude Code / Codex CLIs under your SUBSCRIPTION, not API
# keys. On the worker host run `claude login` (and `codex login` once Codex is
# wired). No ANTHROPIC_API_KEY / OPENAI_API_KEY needed here.

# NotebookLM MCP connector. Run interactive auth once under the same Linux user
# that runs kvz-ai-worker:
#   npx -y notebooklm-mcp-server@3.0.7 auth
# Use a dedicated Google account/profile with access only to selected notebooks.
NOTEBOOKLM_MCP_PACKAGE=notebooklm-mcp-server@3.0.7
