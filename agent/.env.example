# Конфіг воркера (agent/scripts/poll.sh). Runtime values materialize from 1Password.

# База Next.js застосунку
API_URL=https://your-app.vercel.app

# Shared secret — той самий WORKER_TOKEN, що в web runtime
# Згенерувати: openssl rand -hex 32
WORKER_TOKEN=

# Ключ Anthropic API для handle_task.sh
ANTHROPIC_API_KEY=sk-ant-...

# Опційно
# CLAUDE_MODEL=claude-opus-4-8
# POLL_INTERVAL=5
# TOKEN_LIMIT=5000
