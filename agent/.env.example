# Конфіг воркера (agent/scripts/poll.sh). Runtime values materialize from 1Password.

# База Next.js застосунку
API_URL=https://your-app.vercel.app

# Shared secret — той самий WORKER_TOKEN, що в web runtime (це НЕ Anthropic).
# Згенерувати: openssl rand -hex 32
WORKER_TOKEN=

# LLM працює через Claude Code CLI під ПІДПИСКОЮ — НЕ через API-ключ.
# На хості воркера один раз: `claude login` (ваша підписка Pro/Max).
# Жодного ANTHROPIC_API_KEY тут не потрібно.

# Опційно
# CLAUDE_MODEL=opus
# POLL_INTERVAL=5
# TOKEN_LIMIT=5000

# Оркестрація (декомпозиція складених задач у handle_task.sh)
# ORCH_DISABLE=1            # АВАРІЙНИЙ вимикач: лише простий one-executor режим
# ORCH_MAX_CONCURRENCY=3    # паралелізм під-задач
# PLAN_MAX_STEPS=6          # стеля кроків плану (жорсткий максимум — 6)
# ORCH_STEP_TIMEOUT=90      # сек на один CLI-виклик (тримає fan-out під 5-хв watchdog)

# NotebookLM MCP (неофіційний конектор, read-only використання у kvz-ai).
# Перед запуском на хості воркера: `npx -y notebooklm-mcp-server@3.0.7 auth`
# і логін окремим Google-акаунтом, якому відкриті тільки потрібні notebooks.
# Сесія браузера зберігається локально у HOME користувача воркера, не в git/env.
NOTEBOOKLM_MCP_PACKAGE=notebooklm-mcp-server@3.0.7
