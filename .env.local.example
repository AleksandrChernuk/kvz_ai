NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Shared secret для воркера (оркестратора на VPS).
# Згенерувати: openssl rand -hex 32
# Воркер передає його в заголовку: Authorization: Bearer <WORKER_TOKEN>
WORKER_TOKEN=

# Майбутнє (для воркера на VPS, не для Next.js):
