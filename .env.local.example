NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Shared secret для воркера (оркестратора на VPS).
# Згенерувати: openssl rand -hex 32
# Воркер передає його в заголовку: Authorization: Bearer <WORKER_TOKEN>
WORKER_TOKEN=

# Воркер (на окремому хості) використовує Claude Code CLI під ПІДПИСКОЮ
# (`claude login`), а не API-ключі. Тут, у web runtime, LLM-ключі не потрібні.
